{
  "name": "hass-dash",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22",
    "pnpm": "9.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "lighthouse": "lhci autorun",
    "lighthouse:ui": "lhci collect && lhci upload && node scripts/lhci-ui-smoke.mjs",
    "lighthouse:collect": "lhci collect",
    "lighthouse:assert": "lhci assert",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,md}\"",
    "type-check": "tsc --noEmit",
    "test": "node scripts/vitest-batched.mjs",
    "test:watch": "node scripts/vitest-run.mjs",
    "test:all": "node scripts/vitest-batched.mjs --include-slow",
    "test:ui": "node scripts/vitest-run.mjs --ui",
    "test:coverage": "node scripts/vitest-coverage.mjs",
    "test:coverage:all": "node scripts/vitest-coverage.mjs --include-slow",
    "test:run": "node scripts/vitest-run.mjs run",
    "test:e2e": "playwright test",
    "test:pr-check": "pnpm lint && pnpm type-check && pnpm test:coverage && pnpm test:e2e && pnpm build",
    "test:e2e:toast-max-visible": "node scripts/run-toast-max-visible-e2e.mjs",
    "docker:build": "node scripts/docker-image.mjs build",
    "docker:push": "node scripts/docker-image.mjs push",
    "docker:deploy": "node scripts/docker-image.mjs deploy",
    "docker:bg:switch": "node scripts/docker-bluegreen.mjs switch",
    "docker:bg:status": "node scripts/docker-bluegreen.mjs status",
    "pwa:offline-test": "pnpm build && pnpm preview --host --port 5173 --strictPort",
    "pwa:offline-test:note": "Note: run this script only from the same origin (http://localhost:5173) that the PWA is installed from so the service worker scope behaves correctly.",
    "pwa:icons": "node scripts/generate-pwa-icons.mjs"
  },
  "dependencies": {
    "@iconify/react": "^6.0.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toast": "^1.2.15",
    "ajv": "^8.17.1",
    "dompurify": "^3.3.3",
    "immer": "^10.2.0",
    "inversify": "^7.11.0",
    "konva": "^10.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-konva": "^19.2.1",
    "reflect-metadata": "^0.2.2",
    "workbox-window": "^7.4.0",
    "yaml": "^2.8.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^24.10.9",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-istanbul": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "fake-indexeddb": "^6.2.5",
    "globals": "^16.5.0",
    "happy-dom": "^20.4.0",
    "jsdom": "^27.4.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  }
}
