# Environment Variables

# Application Version
VITE_APP_VERSION=0.1.0

# Logging
# Controls client-side console verbosity.
# Allowed: debug | info | warn | error | silent
VITE_LOG_LEVEL=info

# Home Assistant Connection
VITE_HA_BASE_URL=http://homeassistant.local:8123
VITE_HA_WEBSOCKET_URL=ws://homeassistant.local:8123/api/websocket
VITE_HA_ACCESS_TOKEN=your_long_lived_access_token_here

# Dev-only: if your dev machine can't resolve mDNS hostnames like `homeassistant.local`
# (common in some Linux/WSL setups), point the Vite proxy at a resolvable host/IP instead.
# Example: VITE_HA_PROXY_TARGET=http://192.168.1.50:8123
# VITE_HA_PROXY_TARGET=

# Feature Flags
VITE_FEATURE_DEBUG_PANEL=false
# Room Zoom (floorplan room focus/zoom)
VITE_FEATURE_ROOM_ZOOM=false
# Notifications
# Enabled by default. Set any of these to false to disable.
# VITE_FEATURE_NOTIFICATIONS=false
# VITE_FEATURE_NOTIFICATIONS_TOASTS=false
# VITE_FEATURE_NOTIFICATIONS_PERSISTENT=false
# Optional action bridge (camera/panel actions from notification events)
# VITE_FEATURE_NOTIFICATION_ACTIONS=false
# Notifications toast settings
# Default toast auto-dismiss TTL in seconds.
# VITE_NOTIFICATIONS_TOAST_TTL_SECONDS=20
# Max number of visible toasts at once before overflow count is shown.
# VITE_NOTIFICATIONS_TOAST_MAX_VISIBLE=3
# Duplicate suppression window for burst-identical toast events, in milliseconds.
# Set to 0 to disable service-level burst dedupe.
# VITE_NOTIFICATIONS_BURST_DEDUPE_WINDOW_MS=1500
# Optional per-source toast cooldown window in milliseconds.
# Set to 0 (default) to disable source cooldown suppression.
# VITE_NOTIFICATIONS_SOURCE_COOLDOWN_MS=0
# Optional alert-specific override for source cooldown.
# Falls back to VITE_NOTIFICATIONS_SOURCE_COOLDOWN_MS when unset.
# VITE_NOTIFICATIONS_SOURCE_COOLDOWN_ALERT_MS=0
# Optional event-entity-specific override for source cooldown.
# Falls back to VITE_NOTIFICATIONS_SOURCE_COOLDOWN_MS when unset.
# VITE_NOTIFICATIONS_SOURCE_COOLDOWN_EVENT_MS=0
# Optional severity-based cooldown overrides in milliseconds.
# Set any to 0 (default) to disable that severity-level suppression.
# VITE_NOTIFICATIONS_SEVERITY_COOLDOWN_INFO_MS=0
# VITE_NOTIFICATIONS_SEVERITY_COOLDOWN_WARNING_MS=0
# VITE_NOTIFICATIONS_SEVERITY_COOLDOWN_CRITICAL_MS=0
# Optional. Default: true.
# Set to false to make the dashboard take up the full viewport.
# VITE_FEATURE_SHOW_VIRTUAL_PANEL=false

# Dev Server (Vite)
# If you need to change the dev server port (default 5173):
# VITE_DEV_PORT=5173
# If you're developing in WSL2 and testing from another machine, HMR can sometimes
# select an unreachable host. Set this to your Windows LAN IP (not the WSL IP):
# VITE_DEV_HMR_HOST=192.168.1.50
# Dev-only: enable a service worker while running `pnpm dev` so locally installed
# PWAs can exercise SW/update behavior during development.
# This is NOT a full offline-launch substitute for production preview/builds,
# because Vite dev pages reference module URLs like /@vite/client and /src/*.
# Keep this off by default to avoid caching surprises in normal development.
# VITE_PWA_DEV_SW=false

# Tracking
# Minimum confidence required to accept a device position update.
VITE_TRACKING_ESPRESENSE_MIN_CONFIDENCE=69
# Set the next value to display the confidence score when it's below a certain threshold
# VITE_TRACKING_SHOW_CONFIDENCE_WHEN_LESS_THAN=90

# When a tracked device is older than N minutes, keep it visible but render it as stale
# (gray) with a "> N minutes" label.
# Default: 10
VITE_TRACKING_STALE_WARNING_MINUTES=10

# Hide tracked device markers when no update has been received for more than N minutes.
# Default: 30
VITE_TRACKING_STALE_TIMEOUT_MINUTES=30

# Dev-only overlay enabled via URL query params in the UI.
# This controls what raw location values are shown next to each marker.
# Allowed: xyz | geo
VITE_TRACKING_DEBUG_OVERLAY_MODE=xyz

# Docker Host Deployment
# Registry/repository used by docker scripts (for example: geekblaze/hass-dash)
# HASS_DASH_IMAGE_REPO=hass-dash
# Image tag used by docker-compose.host.yml
HASS_DASH_IMAGE=hass-dash:1.0.0
# Blue-green proxy public port (single entrypoint)
# HASS_DASH_BLUEGREEN_PORT=8080
# Optional explicit image override for blue-green switch command.
# HASS_DASH_BLUEGREEN_IMAGE=hass-dash:1.0.0-build.0
# Optional explicit image for each color deployment; usually managed by docker:bg:switch.
# HASS_DASH_BLUE_IMAGE=hass-dash:1.0.0-build.0
# HASS_DASH_GREEN_IMAGE=hass-dash:1.0.0-build.0
# Allowed: restricted | open
HASS_DASH_CORS_MODE=restricted
